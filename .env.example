# Copy to .env.local — never commit real secrets.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Login lockout
# LOGIN_MAX_FAILED_ATTEMPTS=3
# LOGIN_LOCKOUT_MINUTES=45

DB_SETUP_SECRET=your-db-setup-secret
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Seylan sandbox-style gateway (keys stay server-side; optional QR path override)
FINTECH_BASE_URL=http://34.21.206.87:3000
FINTECH_API_KEY=your-fintech-api-key
FINTECH_TEAM_KEY=your-fintech-team-key
FINTECH_TEAM_KEY_HEADER=X-Team-Key
FINTECH_QR_GENERATE_PATH=/Posting/Payments/Qr/1.0/GenerateQrPayment
FINTECH_SOURCE_ACCOUNT=your-source-account
FINTECH_INTERNAL_DEST_ACCOUNT=your-dest-account
FINTECH_BALANCE_ACCOUNT=your-balance-account
FINTECH_CURRENCY_CODE=LKR
FINTECH_TIMEOUT_MS=28000

